{
  "private": true,
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "build:prod": "dotenv -c production -v CI=true -- next build",
    "start": "next start",
    "start:prod": "dotenv -e .env.production.local -e .env.production -- node ./.next/standalone/server.js",
    "ci:prepare-docker": "npx -y docker-deps",
    "lint": "eslint",
    "format": "prettier --list-different .",
    "check-types": "tsc --noEmit",
    "commit": "git-cz",
    "commitlint": "commitlint --edit",
    "db:gen": "pnpm db:generate",
    "db:generate": "dotenv -c development -- prisma generate && pnpm dlx prettier --write ./models/**/*.ts --log-level silent",
    "db:mi": "pnpm db:migrate",
    "db:migrate": "dotenv -c development -- prisma migrate dev",
    "db:push": "dotenv -c development -- prisma db push",
    "db:deploy": "dotenv -c production -- prisma migrate deploy",
    "db:reset": "dotenv -c development -- prisma migrate reset",
    "db:studio": "dotenv -c development -- prisma studio"
  },
