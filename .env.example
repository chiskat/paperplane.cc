# 此文件仅为示例，内容不会被读取，请勿修改此文件
# 请将配置项请写入 .env 等文件

# 按照环境来区分：
#   仅需在生产环境载入的配置项，则使用 .env.production 文件
#   仅需在开发环境载入的配置项，则使用 .env.development 文件

# 以上文件名均可加上 .local 后缀结尾，以 .local 结尾的配置文件不会被 Git 提交

# ==================== 核心配置 ====================

# 部署域名
#   示例： https://example.com 或 http://localhost:3000
NEXT_PUBLIC_BASE_URL =

# CDN 静态资源域名，仅在生产环境生效，所有静态资源都将基于此域名
NEXT_PUBLIC_CDN_BASE_URL =

# 用于 Cookies 加密等场景，建议随机生成
BETTER_AUTH_SECRET =

# PostgreSQL 数据库链接字符串
#   示例： postgresql://user:password@localhost:5432/db_name?schema=public
POSTGRESQL_URL =

# Redis 连接字符串
#   示例： redis://:password@localhost:6379
REDIS_URL =

# ==================== OAuth2 登录认证 ====================

# OAuth2.0 Connect Discovery 地址
OA2_DISCOVERY_URL =

# OAuth2.0 客户端 ID
OA2_CLIENT_ID =

# OAuth2.0 客户端密钥
OA2_CLIENT_SECRET =

# ==================== 各功能模块配置 ====================

# GitHub 代理前缀，访问不畅通时可配置
GITHUB_API_PROXY_PREFIX =

# GitHub 用户令牌
GITHUB_PERSON_TOKEN =

# 博客 Artalk 留言系统服务器地址
NEXT_PUBLIC_ARTALK_SERVER =

# 短链接功能如果使用了外部域名，此处提供外部域名的前缀
NEXT_PUBLIC_EXTERNAL_SHORT_URL_PREFIX =

# ==================== S3 存储配置 ====================

# 开放存储 S3 的替换域名
NEXT_PUBLIC_S3_CNAME =

# 开放存储 S3 的地区
PUBLIC_S3_REGION =

# 开放存储 S3 访问密钥 ID
PUBLIC_S3_ACCESS_KEY_ID =

# 开放存储 S3 访问密钥 Key
PUBLIC_S3_SECRET_ACCESS_KEY =

# 开放存储 S3 存储桶名
PUBLIC_S3_BUCKET_NAME =

# 开放存储 S3 的 endpoint 终端
PUBLIC_S3_ENDPOINT =

# 私有存储 S3 的替换域名
INTERNAL_S3_CNAME =

# 私有存储 S3 的地区
INTERNAL_S3_REGION =

# 私有存储 S3 访问密钥 ID
INTERNAL_S3_ACCESS_KEY_ID =

# 私有存储 S3 访问密钥 Key
INTERNAL_S3_SECRET_ACCESS_KEY =

# 私有存储 S3 存储桶名
INTERNAL_S3_BUCKET_NAME =

# 私有存储 S3 的 endpoint 终端
INTERNAL_S3_ENDPOINT =

# ==================== 邮件服务 ====================

# SMTP 邮件服务主机
SMTP_HOST =

# SMTP 邮件服务端口哈
SMTP_PORT =

# SMTP 邮件服务登录用户名
SMTP_USER =

# SMTP 邮件服务登录密码
SMTP_PASSWD =

# SMTP 邮件服务是否使用加密连接
SMTP_SECURE =

# 通知邮件中表示 “no-reply” 的用户名
MAIL_NOREPLY_NAME =

# 通知邮件使用的发件人邮箱
MAIL_NOREPLY_EMAIL =

# ==================== 第三方服务 ====================

# 聚合数据 油价 API 令牌（https://www.juhe.cn/box/index/id/540）
JUHE_OIL_PRICE_API_KEY =

# 聚合数据 节假日 API 令牌（https://www.juhe.cn/box/index/id/177/600）
JUHE_HOLIDAY_API_KEY =

# 聚合数据 工作日 API 令牌（https://www.juhe.cn/box/index/id/606/1566）
JUHE_WORKDAY_API_KEY =

# 聚合数据 天气 API 令牌（https://www.juhe.cn/box/index/id/73/1213）
JUHE_WEATHER_API_KEY =

# 百度地图令牌（https://lbsyun.baidu.com/faq/api?title=webapi/traffic-ambitusseek）
BAIDU_MAP_KEY =

# 百度地图网页 SDK 令牌（https://lbsyun.baidu.com/apiconsole/key#/home）
NEXT_PUBLIC_BAIDU_MAP_WEBSDK_AK =
